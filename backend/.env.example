# EmpathEase Backend Configuration
# Copy this file to .env and update values

# Application
APP_NAME=EmpathEase
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=empathease
POSTGRES_PASSWORD=dev_password_change_in_prod
POSTGRES_DB=empathease
DATABASE_URL=postgresql+asyncpg://empathease:dev_password_change_in_prod@localhost:5432/empathease

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=episodic_memory

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dev_password_change_in_prod

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM — Groq primary, Ollama fallback
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# Sarvam AI — STT/TTS
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka

# ML Models
FACIAL_MODEL_PATH=app/ml/models/facial_affect.onnx
TEXT_EMOTION_MODEL=distilbert-base-uncased-finetuned-goemotions

# Session Settings
WORKING_MEMORY_TTL=1800  # 30 minutes
MAX_CONVERSATION_TURNS=20

# Safety
CRISIS_THRESHOLD=0.7
ENABLE_PII_SCRUBBING=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
